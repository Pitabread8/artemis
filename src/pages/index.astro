    amount: apolloMissionCosts2025.csm,
    label: '$485.8M',
    title: 'Apollo command/service module mission cost proxy',
    note: 'Based on NASA’s Apollo 11-era mission cost table, which lists the Apollo Command & Service Module at $55M in 1969-era dollars. Inflation-adjusted to November 2025 dollars using BLS CPI-U.',
