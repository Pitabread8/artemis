const contractorKeyOrder = [
  'Northrop Grumman',
  'Boeing',
  'North American Aviation',
  'Douglas Aircraft',
  'Lockheed Martin',
  'Lockheed Propulsion Co.',
  'Aerojet Rocketdyne',
  'Rocketdyne',
  'Teledyne Brown Engineering',
  'IBM',
];

const contractorKey = contractorKeyOrder.reduce((groups, name) => {
  const item = { name, ...contractorStyles[name] };

  if (item.mergedInto) {
    const parentGroup = groups.find((group) => group.name === item.mergedInto);
    if (parentGroup) {
      parentGroup.children.push(item);
      return groups;
    }
  }

  groups.push({ ...item, children: [] });
  return groups;
}, []);

