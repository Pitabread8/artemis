}

      /*astronaut styling*/
    .scroll-container {
      position: relative;
    }

    /* The graphic stays pinned to the top of the viewport */
    .sticky-graphic {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 100%;
    }

    #sankey-svg {
      width: 100%;
      height: 100%;
    }

    /* Each spacer div is one "scene" of reading time */
    .scroll-section {
      height: 100vh;
      /* one full screen = one astronaut */
      /* or use 150vh for slower reveals */
    }

    .end-spacer {
      height: 50vh;
    }

    /* Info card */
    .info-card {
      position: absolute;
      bottom: 40px;
      left: 40px;
      background: rgba(255, 255, 255, 0.8);
      border-radius: 12px;
      padding: 20px;
      width: 800px;
      display: flex;
      gap: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .info-card.hidden {
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
    }

    .phidden {
      display: none;
    }

    .info-card img {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
    }

    @keyframes draw {
      0% {
        stroke-dashoffset: 1000;
      }

