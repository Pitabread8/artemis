const apolloCpi1969 = 36.7;
const apolloCpi2025 = 324.122;
const apolloInflationFactor = apolloCpi2025 / apolloCpi1969;

const apolloMissionCosts2025 = {
  csm: Math.round(55000000 * apolloInflationFactor),
  lm: Math.round(40000000 * apolloInflationFactor),
  saturnV: Math.round(185000000 * apolloInflationFactor),
};

