---
import { priceBibliography } from '../lib/rocket';
import ArticleText from '../components/ArticleText.mdx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Next!: Artemis II and the Modern Space Age</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="any" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <style is:global>
      :root {
        color-scheme: light;
        --font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-family: var(--font);
        --ink: #141414;
        --muted: #62666d;
        --line: #d9d9d9;
        --paper: #fbfbf8;
        --panel: #ffffff;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--paper);
        color: var(--ink);
      }

      body {
        overflow-x: hidden;
      }

      button {
        font: inherit;
      }

      .page-shell {
        display: grid;
        gap: 0;
      }

      .diagram-panel {
        position: relative;
      }

      .article-intro {
        padding: 34px 28px 30px;
        background: var(--paper);
      }

      .article-intro__inner {
        width: min(100%, 920px);
        margin: 0 auto;
        display: grid;
        gap: 14px;
      }

      .article-kicker {
        margin: 0;
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .article-title {
        margin: 0;
        max-width: 12ch;
        font-size: clamp(2.6rem, 6vw, 5.5rem);
        line-height: 0.94;
        letter-spacing: -0.03em;
      }

      .article-subtitle {
        margin: 0;
        max-width: 42rem;
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.5;
      }

      .article-copy {
        margin: 6px 0 0;
        max-width: 42rem;
        font-size: 1rem;
        line-height: 1.7;
      }

      .article-content p {
        margin: 6px 0 0;
        max-width: 42rem;
        font-size: 1rem;
        line-height: 1.7;
      }

      .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: minmax(280px, 380px) 1fr;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .panel {
        position: sticky;
        top: 0;
        height: 100vh;
        min-width: 0;
        padding: 28px;
        border-right: 1px solid var(--line);
        background: var(--panel);
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .panel h1 {
        white-space: nowrap;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4.25rem);
        line-height: 0.92;
        letter-spacing: 0;
        max-width: 6ch;
      }

      .deck {
        margin: 0;
        margin-top: 10px;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.45;
        max-width: 24rem;
      }

      .key {
        display: grid;
        gap: 10px;
      }

      .mode-toggle {
        display: inline-grid;
        grid-auto-flow: column;
        gap: 0;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px;
        background: #f2f3ef;
      }

      .mode-button {
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: var(--muted);
        padding: 8px 14px;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
      }

      .mode-button.is-active {
        background: #fff;
        color: var(--ink);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
      }

      .key h2,
      .details h2 {
        margin: 0 0 4px;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .key-row {
        display: grid;
        grid-template-columns: 18px 1fr;
        gap: 10px;
        align-items: start;
        font-size: 0.95rem;
      }

      .key-group {
        display: grid;
        gap: 8px;
      }

      .key-children {
        display: grid;
        gap: 8px;
        padding-left: 28px;
      }

      .swatch {
        width: 18px;
        height: 18px;
        border: 1px solid rgba(0, 0, 0, 0.28);
      }

      .key-copy {
        display: grid;
        gap: 2px;
      }

      .price-legend {
        display: none;
        gap: 12px;
      }

      .diagram-panel.is-price-mode .contractor-key {
        display: none;
      }

      .diagram-panel.is-price-mode .price-legend {
        display: grid;
      }

      .price-gradient {
        height: 16px;
        border: 1px solid rgba(0, 0, 0, 0.12);
        background: linear-gradient(90deg, #e5f7e8 0%, #0f8e4f 100%);
      }

      .price-scale {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted);
        font-size: 0.76rem;
      }

      .price-copy {
        margin: 0;
        color: var(--muted);
        font-size: 0.82rem;
        line-height: 1.45;
      }

      .price-missing {
        display: grid;
        grid-template-columns: 18px 1fr;
        gap: 10px;
        align-items: start;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .details {
        margin-top: auto;
        width: 100%;
        min-width: 0;
        padding-top: 20px;
        border-top: 1px solid var(--line);
      }

      .details-name {
        margin: 0;
        font-size: 1.1rem;
        line-height: 1.2;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .details-contractor {
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 0.95rem;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .details-price {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 0.9rem;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .details-description {
        margin: 12px 0 0;
        color: var(--ink);
        font-size: 0.9rem;
        line-height: 1.5;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .details-note {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 0.85rem;
        line-height: 1.4;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .stage {
        min-height: 100vh;
        padding: clamp(24px, 4vw, 52px);
        display: grid;
        place-items: center;
      }

      .rocket-slider {
        width: min(100%, 760px);
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: clamp(10px, 2vw, 22px);
        align-items: center;
      }

      .rocket-shell {
        width: 100%;
        min-height: min(88vh, 900px);
        display: grid;
        gap: 16px;
        justify-items: center;
        align-content: center;
      }

      .rocket-window {
        width: min(100%, 620px);
        overflow: hidden;
      }

      .rocket-track {
        display: flex;
        transition: transform 280ms ease;
        will-change: transform;
      }

      .rocket-slide {
        flex: 0 0 100%;
        display: grid;
        justify-items: center;
        gap: 12px;
      }

      .rocket-label {
        font-size: 0.8rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .rocket-controls {
        display: grid;
        gap: 14px;
        justify-items: center;
      }

      .slider-button {
        width: 48px;
        height: 48px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        color: var(--ink);
        display: grid;
        place-items: center;
        cursor: pointer;
        transition:
          background 160ms ease,
          transform 160ms ease,
          border-color 160ms ease;
      }

      .slider-button:hover,
      .slider-button:focus-visible {
        background: #fff;
        border-color: #a9adb3;
        transform: scale(1.04);
        outline: none;
      }

      .slider-button svg {
        width: 18px;
        height: 18px;
      }

      .rocket-pips {
        display: flex;
        gap: 8px;
      }

      .rocket-pip {
        width: 10px;
        height: 10px;
        border: 0;
        border-radius: 999px;
        background: #d2d5da;
        padding: 0;
        cursor: pointer;
      }

      .rocket-pip.is-active {
        background: var(--ink);
      }

      .rocket-svg {
        width: min(100%, 430px);
        height: min(88vh, 900px);
        display: block;
        overflow: visible;
      }

      .rocket-svg .artemis-part {
        fill: var(--part-fill);
        stroke: #1f1f1f;
        stroke-width: 0.72px;
        vector-effect: non-scaling-stroke;
        cursor: crosshair;
        transition:
          filter 160ms ease,
          opacity 160ms ease,
          stroke-width 160ms ease;
      }

      .rocket-svg .artemis-part--group path,
      .rocket-svg .artemis-part--group polyline,
      .rocket-svg .artemis-part--group polygon {
        fill: var(--part-fill);
        stroke: #1f1f1f;
        stroke-width: 0.72px;
        vector-effect: non-scaling-stroke;
      }

      .rocket-svg .artemis-part:hover,
      .rocket-svg .artemis-part:focus-visible,
      .rocket-svg .artemis-part.is-active {
        filter: brightness(1.08) saturate(1.14);
        opacity: 1;
        stroke: #000;
        stroke-width: 1.8px;
        outline: none;
      }

      .rocket-svg .artemis-part--group:hover path,
      .rocket-svg .artemis-part--group:focus-visible path,
      .rocket-svg .artemis-part--group.is-active path,
      .rocket-svg .artemis-part--group:hover polyline,
      .rocket-svg .artemis-part--group:focus-visible polyline,
      .rocket-svg .artemis-part--group.is-active polyline,
      .rocket-svg .artemis-part--group:hover polygon,
      .rocket-svg .artemis-part--group:focus-visible polygon,
      .rocket-svg .artemis-part--group.is-active polygon {
        stroke: #000;
        stroke-width: 1.8px;
      }

      .rocket-svg:has(.artemis-part:hover) .artemis-part:not(:hover),
      .rocket-svg:has(.artemis-part:focus-visible) .artemis-part:not(:focus-visible) {
        opacity: 0.66;
      }

      .tooltip {
        position: absolute;
        z-index: 20;
        left: 0;
        top: 0;
        max-width: min(280px, calc(100% - 28px));
        padding: 10px 12px;
        border: 1px solid rgba(0, 0, 0, 0.18);
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 14px 36px rgba(0, 0, 0, 0.16);
        pointer-events: none;
        opacity: 0;
        transform: translate3d(12px, 12px, 0);
        transition: opacity 120ms ease;
      }

      .tooltip.is-visible {
        opacity: 1;
      }

      .tooltip strong {
        display: block;
        font-size: 0.92rem;
        line-height: 1.2;
        overflow-wrap: anywhere;
      }

      .tooltip span {
        display: block;
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.82rem;
        line-height: 1.3;
        overflow-wrap: anywhere;
      }

      .bibliography {
        padding: clamp(24px, 4vw, 42px);
        background: var(--paper);
      }

      .bibliography h2 {
        margin: 0 0 14px;
        font-size: clamp(1.35rem, 2vw, 1.8rem);
        line-height: 1.05;
      }

      .bibliography-list {
        display: grid;
        gap: 14px;
      }

      .bibliography-item {
        display: grid;
        gap: 4px;
      }

      .bibliography-item a {
        color: inherit;
      }

      .bibliography-item p {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .viz-band {
        display: grid;
        grid-template-columns: minmax(220px, 280px) 1fr;
        gap: 28px;
        padding: clamp(24px, 4vw, 42px);
        border-top: 1px solid var(--line);
        background: #fcfcfa;
      }

      .viz-copy h2 {
        margin: 0 0 10px;
        font-size: clamp(1.35rem, 2vw, 1.8rem);
        line-height: 1.05;
      }

      .viz-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.5;
        max-width: 26rem;
      }

      .viz-frame {
        min-width: 0;
      }

      .viz-canvas {
        position: relative;
        width: 100%;
        padding: 18px;
        border: 1px solid var(--line);
        background: #fff;
      }

      .viz-canvas--grid {
        max-width: 920px;
        margin: 0 auto;
      }

      .component-gap {
        padding: 60px 0;
      }

      .full-bleed {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
      }

      .viz-tooltip {
        position: absolute;
        z-index: 6;
        left: 0;
        top: 0;
        max-width: min(260px, calc(100% - 18px));
        padding: 8px 10px;
        border-radius: 4px;
        background: rgba(17, 17, 17, 0.92);
        color: #fff;
        font-size: 12px;
        line-height: 1.35;
        pointer-events: none;
        transform: translate3d(12px, 12px, 0);
        transition: opacity 120ms ease;
}

      @media (max-width: 780px) {
        .article-intro {
          padding: 26px 22px 24px;
        }

        .article-title {
          max-width: none;
          font-size: 2.8rem;
        }

        .page {
          grid-template-columns: 1fr;
        }

        .panel {
          position: static;
          height: auto;
          min-height: 0;
          border-right: 0;
          border-bottom: 1px solid var(--line);
          padding: 22px;
        }

        h1 {
          max-width: none;
          font-size: 2.4rem;
        }

        .details {
          margin-top: 0;
        }

        .stage {
          min-height: auto;
          padding: 22px 18px 36px;
        }

        .rocket-slider {
          width: 100%;
          grid-template-columns: 1fr;
          gap: 14px;
        }

        .rocket-window {
          order: 1;
          width: 100%;
        }

        .mode-toggle {
          width: 100%;
          grid-auto-flow: column;
          grid-template-columns: 1fr 1fr;
        }

        .slider-button {
          width: 100%;
          height: 42px;
          border-radius: 18px;
        }

        .rocket-shell {
          min-height: auto;
        }

        .rocket-svg {
          width: min(100%, 360px);
          height: auto;
        }

        .viz-band {
          grid-template-columns: 1fr;
          gap: 18px;
          padding: 22px 18px 28px;
        }

        .viz-canvas {
          padding: 10px;
          overflow-x: auto;
        }

        .viz-canvas--grid {
          max-width: 100%;
        }

        .bibliography {
          padding: 22px 18px 28px;
        }
      }
    </style>
  </head>
  <body>
    <main class="page-shell">
      <section class="article-intro" aria-labelledby="article-title">
        <div class="article-intro__inner">
          <p class="article-kicker">Bryan Ammons, Kevin Durand, Mannat Jain, and Sita Vemuri</p>
          <h1 class="article-title" id="article-title">Next!: Artemis II and the Modern Space Age</h1>
          <!-- <p class=”article-subtitle”>A working article about what the Artemis program reveals about NASA’s dependence on private industry, and how that relationship has changed since Apollo.</p> -->
          <div class=”article-content”>
            <ArticleText />
          </div>
        </div>
      </section>

      <section class="bibliography" aria-labelledby="bibliography-title">
        <h2 id="bibliography-title">Data Bibliography</h2>
        <div class="bibliography-list">
          {
            priceBibliography.map((entry) => (
              <div class="bibliography-item">
                <a href={entry.url} target="_blank" rel="noreferrer">{entry.title}</a>
                <p>{entry.note}</p>
              </div>
            ))
          }
        </div>
      </section>
    </main>

    <script>
      function initDiagramPanel(root) {
        const parts = Array.from(root.querySelectorAll('.artemis-part'));
        const tooltip = root.querySelector('[data-tooltip]');
        const tooltipPart = root.querySelector('[data-tooltip-part]');
        const tooltipContractor = root.querySelector('[data-tooltip-contractor]');
        const tooltipPrice = root.querySelector('[data-tooltip-price]');
        const tooltipDescription = root.querySelector('[data-tooltip-description]');
        const detailsName = root.querySelector('[data-details-name]');
        const detailsContractor = root.querySelector('[data-details-contractor]');
        const detailsPrice = root.querySelector('[data-details-price]');
        const detailsDescription = root.querySelector('[data-details-description]');
        const detailsNote = root.querySelector('[data-details-note]');
        const isInlineSimple = root.dataset.inlineSimple === 'true';
        const isInlinePriceSimple = root.dataset.inlinePriceSimple === 'true';
        const hasTooltipDescription = Boolean(tooltipDescription);
        const modeButtons = Array.from(root.querySelectorAll('[data-mode-button]'));
        const slider = root.querySelector('[data-rocket-slider]');
        const track = root.querySelector('[data-rocket-track]');
        const prevButton = root.querySelector('[data-slider-prev]');
        const nextButton = root.querySelector('[data-slider-next]');
        const pips = Array.from(root.querySelectorAll('[data-slider-pip]'));
        const slideCount = Number(slider?.dataset.slideCount ?? root.dataset.slideCount ?? 0);
        let currentSlide = 0;
        let currentMode = root.dataset.initialMode ?? 'contractors';

        function getPriceDisplay(target) {
          const rocket = target.dataset.rocket;
          const isAvailable = target.dataset.priceAvailable === 'true';
          const isEstimated = target.dataset.priceEstimated === 'true';

          if (!isAvailable) {
            return {
              short: 'Price unavailable',
              long: `Price unavailable · ${rocket}`,
              note: target.dataset.priceNote || '',
            };
          }

          const title = target.dataset.priceTitle;
          const label = target.dataset.priceLabel;
          const displayTitle = isEstimated ? `${title} (estimated)` : title;

          return {
            short: `${displayTitle} · ${label}`,
            long: `${displayTitle} · ${label} · ${rocket}`,
            note: target.dataset.priceNote || '',
          };
        }

        function setContent(target) {
          const part = target.dataset.part;
          const rocket = target.dataset.rocket;
          const contractor = target.dataset.contractor;
          const description = target.dataset.description || '';
          const priceDisplay = getPriceDisplay(target);
          const useSimplifiedPriceHover = isInlineSimple || (isInlinePriceSimple && currentMode === 'prices');

          tooltipPart.textContent = part;
          tooltipContractor.textContent = useSimplifiedPriceHover ? description : `${contractor} · ${rocket}`;
          tooltipPrice.textContent = priceDisplay.short;
          if (hasTooltipDescription) {
            tooltipDescription.textContent = useSimplifiedPriceHover ? '' : description;
          }

          if (detailsName) detailsName.textContent = part;
          if (detailsContractor) detailsContractor.textContent = `${contractor} · ${rocket}`;
          if (detailsPrice) detailsPrice.textContent = priceDisplay.long;
          if (detailsDescription) detailsDescription.textContent = description;
          if (detailsNote) detailsNote.textContent = priceDisplay.note || target.dataset.note || '';
        }

        function showTooltip(target) {
          setContent(target);
          tooltip.classList.add('is-visible');
          tooltip.setAttribute('aria-hidden', 'false');
        }

        function hideTooltip() {
          tooltip.classList.remove('is-visible');
          tooltip.setAttribute('aria-hidden', 'true');
        }

        function moveTooltip(event) {
          const offset = 14;
          const panelRect = root.getBoundingClientRect();
          const rect = tooltip.getBoundingClientRect();
          let left = event.clientX - panelRect.left + offset;
          let top = event.clientY - panelRect.top + offset;

          if (left + rect.width > panelRect.width - 10) {
            left = event.clientX - panelRect.left - rect.width - offset;
          }

          if (top + rect.height > panelRect.height - 10) {
            top = event.clientY - panelRect.top - rect.height - offset;
          }

          tooltip.style.transform = `translate3d(${Math.max(10, left)}px, ${Math.max(10, top)}px, 0)`;
        }

        function clearActiveParts() {
          parts.forEach((part) => part.classList.remove('is-active'));
        }

        function getRelatedParts(target) {
          if (currentMode === 'prices') {
            const group = target.dataset.priceGroup;
            if (target.dataset.priceAvailable === 'true' && group) {
              return parts.filter(
                (part) => part.dataset.rocket === target.dataset.rocket && part.dataset.priceGroup === group,
              );
            }

            return [target];
          }

          const group = target.dataset.partGroup;
          return parts.filter(
            (part) => part.dataset.rocket === target.dataset.rocket && part.dataset.partGroup === group,
          );
        }

        function activateRelatedParts(target) {
          clearActiveParts();
          getRelatedParts(target).forEach((part) => part.classList.add('is-active'));
        }

        function updateModeButtons() {
          modeButtons.forEach((button) => {
            const active = button.dataset.mode === currentMode;
            button.classList.toggle('is-active', active);
            button.setAttribute('aria-selected', active ? 'true' : 'false');
          });
        }

        function updatePartFills() {
          parts.forEach((part) => {
            const fill = currentMode === 'prices'
              ? part.dataset.priceColor
              : part.dataset.contractorColor;
            part.style.setProperty('--part-fill', fill);
          });
        }

        function updateMode(mode) {
          currentMode = mode;
          root.classList.toggle('is-price-mode', mode === 'prices');
          updateModeButtons();
          updatePartFills();
          clearActiveParts();
          hideTooltip();
          if (detailsName) detailsName.textContent = 'Rocket component';
          if (detailsContractor) detailsContractor.textContent = 'Hover or focus a colored region.';
          if (detailsPrice) detailsPrice.textContent = '';
          if (detailsDescription) detailsDescription.textContent = '';
          if (detailsNote) detailsNote.textContent = '';
        }

        function updateSlider(index) {
          if (!track || !slideCount) return;

          currentSlide = (index + slideCount) % slideCount;
          track.style.transform = `translateX(-${currentSlide * 100}%)`;

          pips.forEach((pip, pipIndex) => {
            const active = pipIndex === currentSlide;
            pip.classList.toggle('is-active', active);
            pip.setAttribute('aria-pressed', active ? 'true' : 'false');
          });

          clearActiveParts();
          hideTooltip();
        }

        parts.forEach((part) => {
          part.addEventListener('pointerenter', (event) => {
            activateRelatedParts(part);
            showTooltip(part);
            moveTooltip(event);
          });

          part.addEventListener('pointermove', moveTooltip);
          part.addEventListener('pointerleave', () => {
            clearActiveParts();
            hideTooltip();
          });

          part.addEventListener('focus', () => {
            activateRelatedParts(part);
            setContent(part);
          });

          part.addEventListener('blur', () => {
            clearActiveParts();
          });

          part.addEventListener('click', () => {
            activateRelatedParts(part);
            setContent(part);
          });
        });

        prevButton?.addEventListener('click', () => updateSlider(currentSlide - 1));
        nextButton?.addEventListener('click', () => updateSlider(currentSlide + 1));

        pips.forEach((pip) => {
          pip.addEventListener('click', () => {
            updateSlider(Number(pip.dataset.slideIndex ?? 0));
          });
        });

        modeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            updateMode(button.dataset.mode ?? 'contractors');
          });
        });

        updateMode(currentMode);
      }

      document.querySelectorAll('[data-diagram-panel]').forEach((panel) => {
        initDiagramPanel(panel);
      });
    </script>

  </body>
</html>
