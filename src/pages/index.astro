function escapeAttr(value) {
  return String(value).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
}

function normalizeId(id) {
  return id.replace(/-\d+$/, '');
}

function lookupPart(id, partInfo) {
  return partInfo[id] ?? partInfo[normalizeId(id)] ?? null;
}

function isHiddenPart(rocket, id) {
  return rocket.hiddenPartIds.has(id) || rocket.hiddenPartGroups.has(normalizeId(id));
}

function buildNote(info) {
  const style = contractorStyles[info.contractor];
  if (!style?.mergedInto) return info.note ?? '';

  return [info.note, `Later merged into ${style.mergedInto}.`].filter(Boolean).join(' ');
}

function buildDescription(info) {
  return info.description ?? 'Description unavailable for this graphic element.';
}

function hexToRgb(hex) {
  const clean = hex.replace('#', '');
  return {
    r: Number.parseInt(clean.slice(0, 2), 16),
    g: Number.parseInt(clean.slice(2, 4), 16),
    b: Number.parseInt(clean.slice(4, 6), 16),
  };
}

function rgbToHex({ r, g, b }) {
  return `#${[r, g, b].map((value) => Math.round(value).toString(16).padStart(2, '0')).join('')}`;
}

function mixHex(from, to, t) {
  const start = hexToRgb(from);
  const end = hexToRgb(to);
  return rgbToHex({
    r: start.r + (end.r - start.r) * t,
    g: start.g + (end.g - start.g) * t,
    b: start.b + (end.b - start.b) * t,
  });
}

const minPriceAmount = 3000000;
const maxPriceAmount = 10000000000;
const minPriceLabel = '$3M';
const maxPriceLabel = '$10B';
const defaultPriceScaleExponent = 0.6;

function priceColor(amount) {
  const normalized = maxPriceAmount === minPriceAmount
    ? 1
    : (amount - minPriceAmount) / (maxPriceAmount - minPriceAmount);
  const t = Math.pow(Math.max(0, normalized), defaultPriceScaleExponent);
  return mixHex('#e5f7e8', '#0f8e4f', t);
}

function getPriceMeta(info) {
  if (!info.priceGroup) return null;
  const group = priceGroups[info.priceGroup];
  if (!group) return null;

  return {
    ...group,
    color: priceColor(group.amount),
  };
}

function renderRocketSvg(rocket) {
  const rawSvg = fs.readFileSync(rocket.svgPath, 'utf8');

  return rawSvg
    .replace(
      '<svg ',
      `<svg class="rocket-svg rocket-svg--${rocket.slug}" role="img" aria-labelledby="${rocket.slug}-rocket-title ${rocket.slug}-rocket-desc" `,
    )
    .replace(
      /<g id="Layer_2"/,
      `<title id="${rocket.slug}-rocket-title">${rocket.title}</title><desc id="${rocket.slug}-rocket-desc">${rocket.desc}</desc><g id="Layer_2"`,
    )
    .replace(/<g\b([^>]*\bid="([^"]+)"[^>]*)>/g, (match, attrs, id) => {
      if (id === 'Layer_2') return match;
      if (isHiddenPart(rocket, id)) {
        return match;
      }

      const info = lookupPart(id, rocket.parts);
      if (!info) return match;

      const color = contractorStyles[info.contractor]?.color;
      if (!color) return match;
      const priceMeta = getPriceMeta(info);

      const title = `${info.part}: ${info.contractor}`;
      const cleanAttrs = attrs.replace(/\sclass="[^"]*"/g, '');

      return `<g${cleanAttrs} class="artemis-part artemis-part--group" tabindex="0" role="button" style="--part-fill: ${color}" data-part="${escapeAttr(info.part)}" data-contractor="${escapeAttr(info.contractor)}" data-contractor-color="${escapeAttr(color)}" data-description="${escapeAttr(buildDescription(info))}" data-note="${escapeAttr(buildNote(info))}" data-rocket="${escapeAttr(rocket.label)}" data-part-group="${escapeAttr(normalizeId(id))}" data-price-group="${escapeAttr(info.priceGroup ?? '')}" data-price-label="${escapeAttr(priceMeta?.label ?? 'Unavailable')}" data-price-title="${escapeAttr(priceMeta?.title ?? 'Price unavailable')}" data-price-note="${escapeAttr(priceMeta?.note ?? 'No isolated NASA-published part price was found in the reviewed source set.')}" data-price-color="${escapeAttr(priceMeta?.color ?? '#d9ddd9')}" data-price-amount="${escapeAttr(priceMeta?.amount ?? '')}" data-price-source="${escapeAttr(priceMeta?.sourceKey ?? '')}" data-price-estimated="${priceMeta?.estimated ? 'true' : 'false'}" data-price-available="${priceMeta ? 'true' : 'false'}" aria-label="${escapeAttr(title)}">`;
    })
    .replace(/<(path|polyline|polygon)\b([^>]*?)(\s*\/?)>/g, (match, tag, attrs, closing) => {
      const idMatch = attrs.match(/\bid="([^"]+)"/);
      if (!idMatch) return match;

      const id = idMatch[1];
      if (isHiddenPart(rocket, id)) {
        return '';
      }

      const info = lookupPart(id, rocket.parts);
      if (!info) return match;

      const color = contractorStyles[info.contractor]?.color;
      if (!color) return match;
      const priceMeta = getPriceMeta(info);

      const title = `${info.part}: ${info.contractor}`;
      const cleanAttrs = attrs.replace(/\sclass="[^"]*"/g, '');

      return `<${tag}${cleanAttrs} class="artemis-part" tabindex="0" role="button" style="--part-fill: ${color}" data-part="${escapeAttr(info.part)}" data-contractor="${escapeAttr(info.contractor)}" data-contractor-color="${escapeAttr(color)}" data-description="${escapeAttr(buildDescription(info))}" data-note="${escapeAttr(buildNote(info))}" data-rocket="${escapeAttr(rocket.label)}" data-part-group="${escapeAttr(normalizeId(id))}" data-price-group="${escapeAttr(info.priceGroup ?? '')}" data-price-label="${escapeAttr(priceMeta?.label ?? 'Unavailable')}" data-price-title="${escapeAttr(priceMeta?.title ?? 'Price unavailable')}" data-price-note="${escapeAttr(priceMeta?.note ?? 'No isolated NASA-published part price was found in the reviewed source set.')}" data-price-color="${escapeAttr(priceMeta?.color ?? '#d9ddd9')}" data-price-amount="${escapeAttr(priceMeta?.amount ?? '')}" data-price-source="${escapeAttr(priceMeta?.sourceKey ?? '')}" data-price-estimated="${priceMeta?.estimated ? 'true' : 'false'}" data-price-available="${priceMeta ? 'true' : 'false'}" aria-label="${escapeAttr(title)}"${closing}>`;
    });
}

const rocketSlides = rockets.map((rocket) => ({
  ...rocket,
  svg: renderRocketSvg(rocket),
}));

const artemisSlide = rocketSlides.find((rocket) => rocket.slug === 'artemis');
